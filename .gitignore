## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/ActiveState ActiveGo)
*.userprefs

# Mono auto generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Re]leases/
x64/
x86/
build/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017/2019/2022 cache directory
.vs/
# Uncomment if you have tasks that create the project's static files in wwwroot
# wwwroot/lib/

# Publish output
*.[Pp]ublish.xml
*.azurePubxml
# Note: The Microsoft Azure Web App publish settings are sometimes named
#       *.pubxml.user and are thus ignored by the *.user rule above.

# Blazor generated files
_protobuf/

# DB files (SQLite/LocalDB)
*.db
*.db-journal
*.db-shm
*.db-wal

# Rider
.idea/

# VS Code
.vscode/
