<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CHECKMATE</title>
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    
    <!-- Custom Stylesheet -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="dark-theme">
    <script>
        (function() {
            const savedTheme = localStorage.getItem('theme') || 'dark';
            if (savedTheme === 'light') {
                document.body.classList.remove('dark-theme');
                document.body.classList.add('light-theme');
            }
        })();
    </script>
    <header class="app-header glass-panel">
        <div class="header-container">
            <a class="app-logo" asp-controller="Home" asp-action="Index">
                <span class="logo-icon">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="display: block;"><path d="M2 4l3 12h14l3-12-6 7-4-7-4 7-6-7z"></path><path d="M3 20h18v2H3v-2z"></path><path d="M12 2v2M10 3h4"></path></svg>
                </span>
                <span class="logo-text">CHECKMATE</span>
            </a>
            
            <nav class="app-nav">
                <button id="theme-toggle-btn" class="theme-toggle-btn" title="Toggle Light/Dark Mode" aria-label="Toggle Light/Dark Mode">
                    <svg id="theme-icon-sun" class="theme-btn-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="4.22" x2="19.78" y2="5.64"></line></svg>
                    <svg id="theme-icon-moon" class="theme-btn-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display: none;"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
                </button>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="user-profile">
                        <span class="user-welcome">Welcome, <strong class="accent-text">@User.Identity.Name</strong></span>
                        <form asp-controller="Auth" asp-action="Logout" method="post" class="logout-form">
                            <button type="submit" class="btn btn-secondary btn-sm">Log Out</button>
                        </form>
                    </div>
                }
                else
                {
                    <div class="auth-links">
                        <a asp-controller="Auth" asp-action="Login" class="btn btn-secondary btn-sm">Log In</a>
                        <a asp-controller="Auth" asp-action="Register" class="btn btn-primary btn-sm">Sign Up</a>
                    </div>
                }
            </nav>
        </div>
    </header>

    <main class="app-main-content">
        @RenderBody()
    </main>

    <footer class="app-footer">
        <div class="footer-container">
            <p>&copy; @DateTime.UtcNow.Year - all rights reserved to CHECKMATE</p>
        </div>
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
